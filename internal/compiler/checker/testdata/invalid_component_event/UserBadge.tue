<script lang="go">
package fixtures

import tue "github.com/norunners/tue"

type UserBadge struct {
	tue.Comp[struct {
		Name          string       `prop:",required"`
		Payload       func(string) `event:""`
		SelectWithArg func()       `event:""`
		SelectBad     func()       `event:""`
		WrongPayload  func(int)    `event:""`
	}]
}
</script>
