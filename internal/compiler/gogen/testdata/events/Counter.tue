<template>
	<main>
		<p>Count: {{ Count }}</p>
		<button type="button" @click="increment">Increment</button>
	</main>
</template>

<script lang="go">
package fixtures

import tue "github.com/norunners/tue"

type Counter struct {
	tue.Comp[struct {
		Count int `state:""`
	}]
}

func (c *Counter) increment() {
	c.CountSet(c.Count() + 1)
}
</script>
